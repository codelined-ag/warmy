{
  "name": "warmy",
  "version": "1.0.0",
  "description": "Keep your Claude Code and Codex CLI sessions warm — automatically. Sends periodic pings via the Anthropic API to reset the 5-hour rate limit window before it expires.",
  "type": "module",
  "bin": {
    "warmy": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "warmy.png",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": ["claude", "codex", "warmup", "rate-limit", "cli", "anthropic", "openai"],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codelined-ag/warmy.git"
  },
  "homepage": "https://github.com/codelined-ag/warmy#readme",
  "bugs": {
    "url": "https://github.com/codelined-ag/warmy/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  }
}